{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Service Health (Targets Up)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        { "expr": "up", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      }
    },
    {
      "title": "Order Service DB Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        { "expr": "order_db_up", "legendFormat": "DB Connection", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DISCONNECTED", "color": "red" }, "1": { "text": "CONNECTED", "color": "green" } }, "type": "value" }
          ],
          "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      }
    },
    {
      "title": "Active Alerts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        { "expr": "ALERTS{alertstate=\"firing\"}", "legendFormat": "{{alertname}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        }
      }
    },
    {
      "title": "Order Errors Total",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        { "expr": "order_errors_total", "legendFormat": "Errors", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 } ] }
        }
      }
    },
    {
      "title": "Total Requests/sec (all services)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        { "expr": "sum(rate(auth_http_requests_total[1m])) + sum(rate(event_http_requests_total[1m])) + sum(rate(order_http_requests_total[1m])) + sum(rate(user_http_requests_total[1m]))", "legendFormat": "RPS", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 100 } ] }
        }
      }
    },
    {
      "title": "Request Rate per Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        { "expr": "sum(rate(auth_http_requests_total[1m]))", "legendFormat": "auth-service", "refId": "A" },
        { "expr": "sum(rate(event_http_requests_total[1m]))", "legendFormat": "event-service", "refId": "B" },
        { "expr": "sum(rate(order_http_requests_total[1m]))", "legendFormat": "order-service", "refId": "C" },
        { "expr": "sum(rate(user_http_requests_total[1m]))", "legendFormat": "user-service", "refId": "D" },
        { "expr": "sum(rate(chat_http_requests_total[1m]))", "legendFormat": "chat-service", "refId": "E" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Error Rate per Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        { "expr": "sum(rate(auth_http_requests_total{status=~\"4..|5..\"}[1m]))", "legendFormat": "auth errors", "refId": "A" },
        { "expr": "sum(rate(event_http_requests_total{status=~\"4..|5..\"}[1m]))", "legendFormat": "event errors", "refId": "B" },
        { "expr": "sum(rate(order_http_requests_total{status=~\"4..|5..\"}[1m]))", "legendFormat": "order errors", "refId": "C" },
        { "expr": "rate(order_errors_total[1m])", "legendFormat": "order DB errors", "refId": "D" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } }
    },
    {
      "title": "Request Duration p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(auth_http_duration_seconds_bucket[5m]))", "legendFormat": "auth p95", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(order_http_duration_seconds_bucket[5m]))", "legendFormat": "order p95", "refId": "B" },
        { "expr": "histogram_quantile(0.95, rate(event_http_duration_seconds_bucket[5m]))", "legendFormat": "event p95", "refId": "C" },
        { "expr": "histogram_quantile(0.95, rate(user_http_duration_seconds_bucket[5m]))", "legendFormat": "user p95", "refId": "D" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Request Duration p50 (Median)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(auth_http_duration_seconds_bucket[5m]))", "legendFormat": "auth p50", "refId": "A" },
        { "expr": "histogram_quantile(0.50, rate(order_http_duration_seconds_bucket[5m]))", "legendFormat": "order p50", "refId": "B" },
        { "expr": "histogram_quantile(0.50, rate(event_http_duration_seconds_bucket[5m]))", "legendFormat": "event p50", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Go Memory Usage (Heap)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        { "expr": "go_memstats_heap_alloc_bytes{job=\"auth-service\"}", "legendFormat": "auth heap", "refId": "A" },
        { "expr": "go_memstats_heap_alloc_bytes{job=\"event-service\"}", "legendFormat": "event heap", "refId": "B" },
        { "expr": "go_memstats_heap_alloc_bytes{job=\"order-service\"}", "legendFormat": "order heap", "refId": "C" },
        { "expr": "go_memstats_heap_alloc_bytes{job=\"user-service\"}", "legendFormat": "user heap", "refId": "D" },
        { "expr": "go_memstats_heap_alloc_bytes{job=\"chat-service\"}", "legendFormat": "chat heap", "refId": "E" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Go Goroutines per Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        { "expr": "go_goroutines{job=\"auth-service\"}", "legendFormat": "auth", "refId": "A" },
        { "expr": "go_goroutines{job=\"event-service\"}", "legendFormat": "event", "refId": "B" },
        { "expr": "go_goroutines{job=\"order-service\"}", "legendFormat": "order", "refId": "C" },
        { "expr": "go_goroutines{job=\"user-service\"}", "legendFormat": "user", "refId": "D" },
        { "expr": "go_goroutines{job=\"chat-service\"}", "legendFormat": "chat", "refId": "E" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["goticket", "capacity"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "title": "GoTicket Services Dashboard",
  "uid": "goticket-main",
  "version": 2
}
